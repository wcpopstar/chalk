# =============================================================================
# Chalk backend — переменные окружения
# =============================================================================
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env
#
# .env НИКОГДА не коммитится в git (см. .gitignore) — только .env.example.
#
# Формат каждой секции:
#   Название            — переменная окружения
#   Описание            — что она делает и куда используется
#   Пример              — пример значения (не рабочий секрет!)
#   Обязательна         — да/нет (нет = есть значение по умолчанию или фича опциональна)
#   Окружение           — development / production / test / все
# =============================================================================


# ── Supabase ─────────────────────────────────────────────────────────────────
# База данных проекта (Postgres) + auth-хранилище пользователей/токенов.
# Все три ключа берутся в Supabase Dashboard → Project Settings → API.

# SUPABASE_URL
# Описание: базовый URL твоего Supabase-проекта, к которому подключается backend.
# Пример: https://abcdefghijklmnop.supabase.co
# Обязательна: да
# Окружение: все (development, production, test)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# SUPABASE_ANON_KEY
# Описание: публичный (anon) ключ Supabase. Используется для операций
# с ограниченными правами (в рамках Row Level Security). Безопасен для
# фронтенда, но здесь используется backend'ом для не-привилегированных запросов.
# Пример: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Обязательна: да
# Окружение: все (development, production, test)
SUPABASE_ANON_KEY=your_anon_key_here

# SUPABASE_SERVICE_KEY
# Описание: сервисный (service_role) ключ Supabase с полными правами,
# в обход Row Level Security. Используется backend'ом для админских операций
# (создание пользователей, запись refresh-токенов и т.д.).
# ⚠️ СЕКРЕТ. Никогда не передавай его на фронтенд и не логируй.
# Пример: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Обязательна: да
# Окружение: все (development, production, test)
SUPABASE_SERVICE_KEY=your_service_role_key_here


# ── JWT (авторизация) ────────────────────────────────────────────────────────

# JWT_SECRET
# Описание: секретный ключ для подписи и верификации access-токенов (JWT).
# Токены живут 15 минут; см. src/utils/jwt.js. Смена этого значения
# мгновенно разлогинивает всех пользователей (все ранее выданные токены
# становятся невалидными).
# Требования: случайная строка минимум 32 символа. Сгенерировать можно так:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Пример: 3f9a1c8e2b7d4f6a0e9c8b7a6d5e4f3c2b1a0d9e8f7c6b5a4d3e2f1c0b9a8d7e
# Обязательна: да
# Окружение: все (development, production, test)
# ⚠️ В production и dev должны быть РАЗНЫЕ значения, никогда не используй
# один и тот же секрет в нескольких окружениях.
JWT_SECRET=your_super_secret_jwt_key_min_32_chars


# ── Agora (голосовые/видео звонки) ──────────────────────────────────────────
# Используются для генерации токенов доступа к голосовым каналам
# (src/routes/agora.js). Берутся в Agora Console → твой проект → Project Kit.

# AGORA_APP_ID
# Описание: идентификатор приложения Agora, определяет к какому проекту
# Agora подключается клиент.
# Пример: 20b7a1e4c9d84f6ab1e2f3c4d5e6f7a8
# Обязательна: да (без неё голосовые звонки не будут работать)
# Окружение: все (development, production, test)
AGORA_APP_ID=your_agora_app_id

# AGORA_APP_CERTIFICATE
# Описание: сертификат приложения, используется вместе с AGORA_APP_ID для
# подписи временных токенов доступа к каналу (RTC token).
# ⚠️ СЕКРЕТ. Не должен попадать на фронтенд.
# Пример: 5c8b3a1f9e7d6c4b2a0f8e6d4c2b0a9f
# Обязательна: да (без неё голосовые звонки не будут работать)
# Окружение: все (development, production, test)
AGORA_APP_CERTIFICATE=your_agora_app_certificate


# ── SMTP (письма — сброс пароля) ────────────────────────────────────────────
# Используется для отправки писем со ссылкой сброса пароля
# (src/services/mailer.js). Если SMTP_HOST не задан — backend НЕ падает:
# вместо реальной отправки письмо просто печатается в лог сервера. Это удобно
# для локальной разработки (ссылку для сброса пароля видно в консоли),
# но в production SMTP обязательно нужно настроить, иначе пользователи не
# смогут восстановить пароль по email.

# SMTP_HOST
# Описание: адрес SMTP-сервера для отправки писем.
# Пример: smtp.sendgrid.net
# Обязательна: нет в development (без неё письма просто логируются в консоль),
# фактически обязательна в production
# Окружение: production (рекомендуется), development (опционально)
SMTP_HOST=smtp.sendgrid.net

# SMTP_PORT
# Описание: порт SMTP-сервера. 587 — STARTTLS (по умолчанию, если не задано),
# 465 — SSL/TLS (secure-режим включается автоматически, если указать именно 465).
# Пример: 587
# Обязательна: нет (по умолчанию 587)
# Окружение: production (рекомендуется), development (опционально)
SMTP_PORT=587

# SMTP_USER
# Описание: логин для авторизации на SMTP-сервере. Если не задан — письма
# отправляются без авторизации (auth: undefined), что подходит не для всех
# провайдеров.
# Пример: apikey
# Обязательна: нет (зависит от требований твоего SMTP-провайдера)
# Окружение: production (рекомендуется), development (опционально)
SMTP_USER=your_smtp_username

# SMTP_PASS
# Описание: пароль/API-ключ для авторизации на SMTP-сервере.
# ⚠️ СЕКРЕТ.
# Пример: SG.xxxxxxxxxxxxxxxxxxxxxxxx
# Обязательна: нет (нужна только вместе с SMTP_USER)
# Окружение: production (рекомендуется), development (опционально)
SMTP_PASS=your_smtp_password

# SMTP_FROM
# Описание: адрес отправителя в поле "From" у писем со сбросом пароля.
# Пример: Chalk <no-reply@chalk.gg>
# Обязательна: нет (по умолчанию "Chalk <no-reply@chalk.gg>")
# Окружение: production (рекомендуется), development (опционально)
SMTP_FROM=Chalk <no-reply@chalk.gg>


# ── Сервер ───────────────────────────────────────────────────────────────────

# PORT
# Описание: порт, на котором Express-сервер принимает HTTP/WebSocket-соединения.
# На Railway и большинстве хостингов PORT подставляется платформой
# автоматически — переопределять вручную в production обычно не нужно.
# Пример: 3000
# Обязательна: нет (по умолчанию 3000)
# Окружение: development (задаётся вручную), production (обычно задаётся платформой)
PORT=3000

# NODE_ENV
# Описание: окружение выполнения приложения. Влияет на уровень логирования
# по умолчанию (production → info, иначе → debug), формат вывода логов и т.д.
# Пример: development
# Обязательна: нет (по умолчанию development)
# Окружение: все — значение должно точно соответствовать реальному окружению
# (development / production / test)
NODE_ENV=development

# LOG_LEVEL
# Описание: явный уровень логирования (pino), переопределяет дефолт
# из NODE_ENV. Допустимые значения: trace, debug, info, warn, error, fatal.
# Пример: debug
# Обязательна: нет (по умолчанию: debug в dev, info в production)
# Окружение: все (опционально)
LOG_LEVEL=debug

# CLIENT_URL
# Описание: origin фронтенда, разрешённый в CORS и Socket.io CORS
# (Access-Control-Allow-Origin). В production ОБЯЗАТЕЛЬНО указывать точный
# домен, а не "*" — иначе credentials (куки/токены) через CORS работать не будут.
# Пример: https://chalk-production-01b7.up.railway.app
# Обязательна: нет технически (по умолчанию "*" — разрешены все origin),
# но фактически обязательна в production по соображениям безопасности
# Окружение: все (development — обычно http://localhost:xxxx, production — реальный домен)
CLIENT_URL=http://localhost:5173


# ── Redis (realtime-состояние: онлайн-статусы, комнаты, matchmaking,
#    Socket.io adapter для мультиинстанс-масштабирования) ───────────────────

# REDIS_URL
# Описание: строка подключения к Redis. Используется для: очередей
# matchmaking (src/services/matchmakingRedis.js), Socket.io Redis-адаптера
# (синхронизация событий между несколькими инстансами сервера), presence/
# онлайн-статусов и других realtime-данных.
# Если переменная не задана — приложение по умолчанию пытается подключиться
# к redis://127.0.0.1:6379 (локальный Redis). Это ломается в production,
# если Redis не запущен в том же контейнере (см. src/config/env.js —
# явно логируется предупреждение, если REDIS_URL не задан в production).
# Пример (локально):        redis://127.0.0.1:6379
# Пример (Railway/managed): redis://default:password@redis.railway.internal:6379
# Обязательна: технически нет (есть дефолт для localhost), но ФАКТИЧЕСКИ
# обязательна в production/staging — без реального Redis matchmaking,
# presence и Socket.io между несколькими инстансами работать не будут.
# Окружение: development (можно оставить дефолт, если Redis крутится локально),
# production (обязательно задать явно)
REDIS_URL=redis://127.0.0.1:6379


# =============================================================================
# Примечания для нового разработчика
# =============================================================================
# 1. Для локальной разработки минимально необходимы:
#    SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY, JWT_SECRET
#    — без них сервер не стартует (см. validateEnv() в src/config/env.js).
#
# 2. AGORA_* нужны только для голосовых/видеозвонков — остальной функционал
#    (чаты, друзья, matchmaking) без них работает, просто звонки будут
#    падать с ошибкой при попытке получить токен канала.
#
# 3. SMTP_* можно вообще не задавать в development — ссылка для сброса
#    пароля будет просто выводиться в лог сервера вместо реальной отправки.
#
# 4. REDIS_URL можно не задавать локально, если у тебя запущен Redis на
#    порту по умолчанию (127.0.0.1:6379), например через:
#      docker run -p 6379:6379 redis:alpine
#    В production/staging задавай его ВСЕГДА явно.
#
# 5. Railway (и большинство PaaS) подставляют PORT автоматически — не нужно
#    задавать его вручную в переменных окружения хостинга.
# =============================================================================
