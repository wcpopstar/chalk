# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ── Agora (voice calls) ───────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Redis (realtime state: online/rooms/matchmaking/invites) ──
# Local dev default is redis://127.0.0.1:6379 if unset.
# In staging/production, always set this explicitly (e.g. a managed
# Redis/Upstash/Elasticache URL) so every server instance shares state.
REDIS_URL=redis://127.0.0.1:6379

# ── Railway sets PORT automatically in production ─
