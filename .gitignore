# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build output — generated by `npm run build`, never hand-edited
dist/

# Bundled frontend — generated by `npm run build:client`, never hand-edited
public/build/

# OS/editor cruft
.DS_Store

# Logs
*.log
npm-debug.log*

# Husky's internal helper dir, not the hooks themselves
.husky/_

# Tauri (desktop) — Rust build artifacts & generated schemas
src-tauri/target/
src-tauri/gen/

# Capacitor / iOS — generated by `cap sync`/Xcode, never hand-edited.
# The web assets under ios/App/App/public are a copy of public/, and
# build/DerivedData are Xcode output — regenerated, must not be committed.
ios/App/App/public/
ios/App/build/
ios/DerivedData/
ios/App/App/App.entitlements.plist.bak
